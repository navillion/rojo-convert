      <Properties>
        <string name="Name">Constants</string>
        <string name="Source"><![CDATA[local Constants = {
	PLUGIN_NAME = "Rojo-convert",
	TOOLBAR_NAME = "Plugins",
	BUTTON_ID = "Rojo-convert",
	BUTTON_TOOLTIP = "Export the current Studio selection to a Rojo-compatible file tree on your computer.",
	DEDUPED_NAME_BUTTON_ID = "Rojo-convert-file-names",
	DEDUPED_NAME_BUTTON_TOOLTIP = "Export the current selection, but keep duplicate-renamed filesystem names in init.meta.json.",
	SERVER_URL_SETTING = "RojoConvertServerUrl",
	DEFAULT_SERVER_URL = "http://127.0.0.1:34873/export",
	FORMAT_VERSION = 1,
}

return Constants
]]></string>
      </Properties>
